{
  "name": "react-flowmap",
  "version": "0.2.8",
  "type": "module",
  "description": "Runtime component inspector and visual graph explorer for React + Vite.",
  "license": "MIT",
  "keywords": [
    "react",
    "vite",
    "devtools",
    "inspector",
    "component",
    "flowmap",
    "debug"
  ],
  "packageManager": "pnpm@10.19.0",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./vite": {
      "import": "./dist/vite-plugin.js",
      "types": "./dist/vite-plugin.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "pnpm demo:dev",
    "demo:dev": "vite --mode demo",
    "demo:tanstack": "pnpm --filter react-flowmap-demo-tanstack dev",
    "build:css": "node scripts/build-inspector-css.mjs",
    "build": "pnpm build:css && pnpm typecheck && vite build --mode library",
    "build:demo": "pnpm typecheck && vite build --mode demo",
    "demo:preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "release:version": "changeset version",
    "release:publish": "pnpm build && changeset publish"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17",
    "vite": ">=5"
  },
  "dependencies": {
    "@babel/generator": ">=7",
    "@babel/parser": ">=7",
    "@babel/traverse": ">=7",
    "@babel/types": ">=7",
    "lucide-react": "^0.577.0",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "9.35.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "22.15.30",
    "@types/react": "19.1.12",
    "@types/react-dom": "19.1.9",
    "@vitejs/plugin-react": "5.0.2",
    "eslint": "9.35.0",
    "globals": "16.3.0",
    "jsdom": "26.1.0",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "tailwindcss": "^4.2.1",
    "typescript": "5.8.3",
    "typescript-eslint": "8.42.0",
    "vite": "7.1.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "3.2.4"
  }
}
