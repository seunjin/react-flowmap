{
  "name": "gori",
  "version": "0.1.0",
  "type": "module",
  "description": "Runtime component inspector for React applications.",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./vite-plugin": "./src/vite-plugin/index.ts"
  },
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "dev": "pnpm demo:dev",
    "demo:dev": "vite --mode demo",
    "build": "pnpm typecheck && vite build --mode library",
    "build:demo": "pnpm typecheck && vite build --mode demo",
    "demo:preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "devDependencies": {
    "@eslint/js": "9.35.0",
    "@types/node": "22.15.30",
    "@types/react": "19.1.12",
    "@types/react-dom": "19.1.9",
    "@vitejs/plugin-react": "5.0.2",
    "eslint": "9.35.0",
    "globals": "16.3.0",
    "jsdom": "26.1.0",
    "ts-morph": "^27.0.2",
    "typescript": "5.8.3",
    "typescript-eslint": "8.42.0",
    "vite": "7.1.4",
    "vitest": "3.2.4"
  }
}
